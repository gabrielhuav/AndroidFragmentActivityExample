<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Título del Fragment -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fragment de Bienvenida 7CV3"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="16dp"
            android:textColor="@color/design_default_color_primary" />

        <!-- Descripción -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Este es tu primer Fragment. Los Fragments son componentes reutilizables que contienen una parte de la interfaz de usuario."
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginBottom="24dp"
            android:lineSpacingExtra="4dp" />

        <!-- Imagen decorativa -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@android:drawable/sym_def_app_icon"
            android:layout_marginBottom="24dp"
            android:contentDescription="Icono de la app" />

        <!-- Campo de texto para el nombre -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Ingresa tu nombre">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnSaludar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saludar"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnLimpiar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Limpiar"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <!-- Botón para abrir el segundo fragment -->
        <Button
            android:id="@+id/btnOpenSecond"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 Abrir Segundo Fragment"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.Button.UnelevatedButton" />


        <!-- Botón para abrir nueva Activity -->
        <Button
            android:id="@+id/btnOpenActivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌟 Abrir Nueva Activity"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.Button" />

        <!-- TextView para mostrar el resultado -->
        <TextView
            android:id="@+id/tvResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textAlignment="center"
            android:background="@color/design_default_color_surface"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:textColor="@color/design_default_color_on_surface" />

        <!-- Información adicional -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 Tip: Los Fragments son perfectos para crear interfaces modulares y reutilizables. Puedes añadir más Fragments fácilmente a esta estructura."
            android:textSize="14sp"
            android:textAlignment="center"
            android:layout_marginTop="32dp"
            android:padding="12dp"
            android:background="@color/design_default_color_primary_variant"
            android:textColor="@android:color/white"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</ScrollView>