<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Título del Fragment -->
        <TextView
            android:id="@+id/tvFragmentTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👋 ¡Bienvenido!"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="16dp" />

        <!-- Información del tema actual -->
        <TextView
            android:id="@+id/tvThemeInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tema actual: Sistema 🌓"
            android:textSize="16sp"
            android:textAlignment="center"
            android:padding="12dp"
            android:background="?attr/colorPrimaryContainer"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:layout_marginBottom="24dp" />

        <!-- Card con información del Fragment -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📚 Acerca de este Fragment"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Este es el WelcomeFragment que se carga dentro de MainActivity. Demuestra cómo los fragments pueden coexistir con activities y mantener consistencia visual con el sistema de temas."
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Botones de acción -->
        <Button
            android:id="@+id/btnNavigateFromFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 Navegar a SecondActivity"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.Button" />

        <Button
            android:id="@+id/btnShowInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ℹ️ Mostrar Información"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.Button.TonalButton" />

        <!-- Área para mostrar información adicional -->
        <TextView
            android:id="@+id/tvFragmentInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:padding="16dp"
            android:background="?attr/colorSecondaryContainer"
            android:textColor="?attr/colorOnSecondaryContainer"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</ScrollView>